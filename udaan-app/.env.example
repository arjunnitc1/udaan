# Copy this file to .env.local and fill in your real key.
# Get your key at https://console.anthropic.com  (set a low spend cap while developing)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model used by the coach. Sonnet-class recommended for live-demo speed.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---- OPTIONAL: database (leave blank to run with in-memory sessions) ----
# When you add Supabase/Neon, put the Postgres connection string here.
DATABASE_URL=
