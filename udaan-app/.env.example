# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it is already in .gitignore.

# ── Anthropic (required for the live coach) ──────────────────────────────────
# Get your key at https://console.anthropic.com — set a low spend cap while developing.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model used by the coach. Sonnet-class recommended for live-demo speed.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Supabase / PostgreSQL (required for session analytics & kit storage) ──────
# Use the "Session mode" pooler URL from your Supabase project dashboard:
#   Project → Settings → Database → Connection string → Session mode
# e.g. postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@[host]:5432/postgres

# ── Upstash Redis (required for persistent rate limiting across serverless fns)
# Create a free database at https://console.upstash.com
# Copy the REST URL and REST token from the dashboard.
UPSTASH_REDIS_REST_URL=https://[your-db].upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: DATABASE_URL for Drizzle Kit CLI (same value as above) ─────────
# drizzle-kit reads this from the environment automatically.
